generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Card {
  name              String
  id                Int                 @id @default(autoincrement())
  card_id           String              @unique
  image_url         String
  rarity            Int
  hp                Int                 @default(0)
  type              String              @default("none")
  Promotional_Cards Promotional_Cards[]
  Cards_user        Cards_user[]
  Trade_Card        Trade_Card[]
  trade_offer_cards trade_offer_cards[]
  User_Purchase     User_Purchase[]

  @@map("cards")
}

model Package {
  price                 Int
  id                    Int             @id @default(autoincrement())
  common_rarity         Float
  rare_rarity           Float
  epic_rarity           Float
  legendary_rarity      Float
  full_legendary_rarity Float
  name                  String
  image_url             String
  cards_quantity        Int
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @default(now()) @updatedAt
  tcg_id                String?
  description           String?
  Packages_User         Packages_User[]
  User_Purchase         User_Purchase[]

  @@map("packages")
}

model Packages_User {
  id        Int      @id @default(autoincrement())
  userId    Int
  packageId Int
  opened    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("packages_user")
}

model Cards_user {
  id        Int      @id @default(autoincrement())
  userId    Int
  cardId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cards_user")
}

model User {
  id                                               Int                @id @default(autoincrement())
  username                                         String
  password                                         String
  email                                            String
  createdAt                                        DateTime           @default(now())
  updatedAt                                        DateTime           @default(now()) @updatedAt
  money                                            Int                @default(500)
  last_daily_bounty                                DateTime?          @default(now())
  last_entry                                       DateTime           @default(now())
  isAdmin                                          Boolean            @default(false)
  isGuest                                          Boolean            @default(false)
  picture                                          String             @default("/wallpaper.jpg")
  daily_bounty_level                               Int                @default(1)
  fromReferralId                                   Int?
  rarityPoints                                     Int                @default(0)
  totalBudget                                      Int                @default(500)
  authProvider                                     String             @default("email")
  last_online                                      DateTime           @default(now())
  online                                           Boolean            @default(false)
  Referred                                         Referred[]
  ReferrerProtocol                                 ReferrerProtocol[]
  Transaction                                      Transaction[]
  Cards_user                                       Cards_user[]
  friendOf                                         Friend_User[]      @relation("UserIsFriendOf")
  friendships                                      Friend_User[]      @relation("UserFriends")
  messages_messages_receiver_idTousers             messages[]         @relation("messages_receiver_idTousers")
  messages_messages_sender_idTousers               messages[]         @relation("messages_sender_idTousers")
  money_donate_money_donate_receiver_idTousers     money_donate[]     @relation("money_donate_receiver_idTousers")
  money_donate_money_donate_sender_idTousers       money_donate[]     @relation("money_donate_sender_idTousers")
  notifications                                    notifications[]
  Packages_User                                    Packages_User[]
  QuestUser                                        QuestUser[]
  trade_offers                                     trade_offers[]
  trade_requests_trade_requests_receiver_idTousers trade_requests[]   @relation("trade_requests_receiver_idTousers")
  trade_requests_trade_requests_sender_idTousers   trade_requests[]   @relation("trade_requests_sender_idTousers")
  User_Purchase                                    User_Purchase[]
  User_Ranking                                     User_Ranking?
  Trade_User                                       User_Trade[]

  @@map("users")
}

model Trade {
  id             Int             @id @default(autoincrement())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
  acceptMoney    Boolean
  acceptOffers   Boolean
  description    String          @default("")
  expiresAt      DateTime?
  hash           String          @unique
  maxRarity      Int             @default(6)
  minRarity      Int             @default(1)
  moneyReceiving Int             @default(0)
  moneySending   Int             @default(0)
  name           String
  protocol       String          @default("1x1")
  public         Boolean         @default(true)
  cards          Trade_Card[]
  trade_offers   trade_offers[]
  trade_requests trade_requests?
  userTrades     User_Trade[]

  @@map("trades")
}

model User_Trade {
  id        Int      @id @default(autoincrement())
  user_id   Int
  trade_id  Int
  is_sender Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Trade     Trade    @relation(fields: [trade_id], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_trade")
}

model Trade_Card {
  id        Int      @id @default(autoincrement())
  card_id   Int
  is_sender Boolean
  trade_id  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Card      Card     @relation(fields: [card_id], references: [id], onDelete: Cascade)
  Trade     Trade    @relation(fields: [trade_id], references: [id], onDelete: Cascade)

  @@map("trade_card")
}

model Friend_User {
  id        Int      @id @default(autoincrement())
  user_id   Int
  accepted  Boolean  @default(false)
  friend_id Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Friend    User     @relation("UserIsFriendOf", fields: [friend_id], references: [id], onDelete: Cascade)
  User      User     @relation("UserFriends", fields: [user_id], references: [id], onDelete: Cascade)

  @@map("friend_user")
}

model Banner {
  id          Int      @id @default(autoincrement())
  image_url   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  active      Boolean  @default(false)
  title       String
  description String
  anchor      String?

  @@map("banners")
}

model User_Ranking {
  user_id      Int  @unique
  total_rarity Int  @default(0)
  position     Int
  user         User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_ranking")
}

model Promotional_Cards {
  card_id        Int
  price          Int
  original_price Int
  id             Int      @id @default(autoincrement())
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
  card           Card     @relation(fields: [card_id], references: [id], onDelete: Cascade)
}

model Transaction {
  id             String   @id @default(uuid())
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())
  status         String
  user_id        Int
  error          String?
  User           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model User_Purchase {
  id         Int      @id @default(autoincrement())
  user_id    Int
  package_id Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  quantity   Int      @default(1)
  card_id    Int?
  Card       Card?    @relation(fields: [card_id], references: [id], onDelete: Cascade)
  Package    Package? @relation(fields: [package_id], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_purchase")
}

model ReferrerProtocol {
  id                Int        @id @default(autoincrement())
  referrerCreatorId Int
  hash              String     @unique
  referreds         Referred[]
  referrerCreator   User       @relation(fields: [referrerCreatorId], references: [id], onDelete: Cascade)
}

model Referred {
  id                 Int              @id @default(autoincrement())
  referredId         Int
  referrerProtocolId Int
  createdAt          DateTime         @default(now())
  bountyRedeemed     Boolean          @default(false)
  updatedAt          DateTime         @default(now()) @updatedAt
  referred           User             @relation(fields: [referredId], references: [id], onDelete: Cascade)
  referrerProtocol   ReferrerProtocol @relation(fields: [referrerProtocolId], references: [id], onDelete: Cascade)
}

model Quest {
  id            Int         @id @default(autoincrement())
  createdAt     DateTime    @default(now())
  levelCount    Int
  levelGoals    Int[]
  levelRewards  Int[]
  name          String
  queryCheck    String
  description   String[]
  isDiary       Boolean     @default(false)
  isDiaryActive Boolean?    @default(false)
  QuestUser     QuestUser[]

  @@map("quests")
}

model QuestUser {
  id           Int      @id @default(autoincrement())
  user_id      Int
  quest_id     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  completed    Boolean  @default(false)
  currentLevel Int      @default(0)
  Quest        Quest    @relation(fields: [quest_id], references: [id], onDelete: Cascade)
  User         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("quest_user")
}

model messages {
  id                                Int      @id @default(autoincrement())
  sender_id                         Int
  receiver_id                       Int
  content                           String
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @default(now())
  viewed                            Boolean  @default(false)
  users_messages_receiver_idTousers User     @relation("messages_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade)
  users_messages_sender_idTousers   User     @relation("messages_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade)
}

model money_donate {
  id                                    Int      @id @default(autoincrement())
  receiver_id                           Int
  sender_id                             Int
  amount                                Int
  createdAt                             DateTime @default(now())
  updatedAt                             DateTime @default(now())
  users_money_donate_receiver_idTousers User     @relation("money_donate_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade)
  users_money_donate_sender_idTousers   User     @relation("money_donate_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade)
}

model notifications {
  id        Int      @id @default(autoincrement())
  user_id   Int
  type      String
  content   String
  thumbnail String?
  createdAt DateTime @default(now())
  viewed    Boolean  @default(false)
  users     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model trade_offer_cards {
  id           Int          @id @default(autoincrement())
  card_id      Int
  trade_id     Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now())
  cards        Card         @relation(fields: [card_id], references: [id], onDelete: Cascade)
  trade_offers trade_offers @relation(fields: [trade_id], references: [id], onDelete: Cascade)
}

model trade_offers {
  id                Int                 @id @default(autoincrement())
  trade_id          Int
  user_id           Int
  money             Int
  createdAt         DateTime            @default(now())
  trade_offer_cards trade_offer_cards[]
  trades            Trade               @relation(fields: [trade_id], references: [id], onDelete: Cascade)
  users             User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model trade_requests {
  id                                      Int      @id @unique @default(autoincrement())
  receiver_id                             Int
  sender_id                               Int
  createdAt                               DateTime @default(now())
  updatedAt                               DateTime @default(now())
  accepted                                Boolean  @default(false)
  revoked                                 Boolean  @default(false)
  tradeId                                 Int      @unique
  users_trade_requests_receiver_idTousers User     @relation("trade_requests_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade)
  users_trade_requests_sender_idTousers   User     @relation("trade_requests_sender_idTousers", fields: [sender_id], references: [id], onDelete: Cascade)
  trades                                  Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}
